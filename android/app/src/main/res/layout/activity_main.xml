<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A2E"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📋 Auto Chấm Công"
            android:textSize="28sp"
            android:textColor="#E0E0FF"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tv_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔴 Service chưa bật"
            android:textSize="16sp"
            android:textColor="#AAAACC"
            android:gravity="center"
            android:layout_marginBottom="24dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="API URL"
            android:textColor="#8888BB"
            android:textSize="13sp"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/et_api_url"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="https://your-bot.fly.dev"
            android:inputType="textUri"
            android:textColor="#FFFFFF"
            android:textColorHint="#555577"
            android:background="@drawable/input_bg"
            android:paddingHorizontal="12dp"
            android:textSize="15sp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="API Secret"
            android:textColor="#8888BB"
            android:textSize="13sp"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/et_api_secret"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="your-api-secret"
            android:inputType="textPassword"
            android:textColor="#FFFFFF"
            android:textColorHint="#555577"
            android:background="@drawable/input_bg"
            android:paddingHorizontal="12dp"
            android:textSize="15sp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Telegram ID"
            android:textColor="#8888BB"
            android:textSize="13sp"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/et_telegram_id"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="123456789"
            android:inputType="number"
            android:textColor="#FFFFFF"
            android:textColorHint="#555577"
            android:background="@drawable/input_bg"
            android:paddingHorizontal="12dp"
            android:textSize="15sp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Humax Package Name"
            android:textColor="#8888BB"
            android:textSize="13sp"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/et_humax_package"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="com.humax.xxx"
            android:inputType="text"
            android:textColor="#FFFFFF"
            android:textColorHint="#555577"
            android:background="@drawable/input_bg"
            android:paddingHorizontal="12dp"
            android:textSize="15sp"
            android:layout_marginBottom="24dp" />

        <Button
            android:id="@+id/btn_save"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="💾 Lưu cấu hình"
            android:textSize="16sp"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btn_open_accessibility"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="⚙️ Bật Accessibility Service"
            android:textSize="16sp"
            style="@style/Widget.Material3.Button.OutlinedButton" />

    </LinearLayout>
</ScrollView>
